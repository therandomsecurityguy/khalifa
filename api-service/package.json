{
  "name": "api-service",
  "version": "1.0.0",
  "description": "Security Graph API Service",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b && tsc --noEmit",
    "pretest": "tsc -b",
    "prebuild": "tsc -b ../packages/risk-engine",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.450.0",
    "@aws-sdk/client-secrets-manager": "^3.1073.0",
    "@aws-sdk/lib-dynamodb": "^3.450.0",
    "@aws-sdk/util-dynamodb": "^3.450.0",
    "@khalifa/risk-engine": "*",
    "express": "^4.18.2",
    "gremlin": "^3.6.2",
    "jose": "^4.15.9"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/gremlin": "^3.6.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
